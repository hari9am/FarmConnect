# Add these environment variables in your Vercel dashboard under Project Settings > Environment Variables

# JWT Secret for authentication
SESSION_SECRET=your-secret-key-here

# Twilio Configuration (optional - if you want real SMS)
TWILIO_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SERVICE_ID=your_twilio_verify_service_id

# MongoDB Connection (if you need database connectivity)
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/farmconnect
